<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Silverback AI Agency — Strength · Wisdom · Compassion</title>
  <meta name="description" content="Silverback AI Agency builds autonomous systems and AI-powered operations for businesses that refuse to slow down." />
  <meta property="og:title" content="Silverback AI Agency" />
  <meta property="og:description" content="Autonomous systems. Ruthless efficiency. Built for operators who refuse to lose." />
  <meta property="og:type" content="website" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --gold:   #facc15;
      --gold2:  #fbbf24;
      --slate:  #94a3b8;
      --dark0:  #030712;
      --dark1:  #0a0a0a;
      --dark2:  #111827;
      --dark3:  #1e293b;
      --accent: #818cf8;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;
      background: var(--dark0);
      color: #f1f5f9;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ── Ambient background grid ── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(250,204,21,.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(250,204,21,.03) 1px, transparent 1px);
      background-size: 48px 48px;
      pointer-events: none;
      z-index: 0;
    }

    /* ── Nav ── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.2rem 2.5rem;
      background: rgba(3,7,18,.85);
      border-bottom: 1px solid rgba(250,204,21,.12);
      backdrop-filter: blur(16px);
    }
    .nav-logo {
      display: flex;
      align-items: center;
      gap: .75rem;
      text-decoration: none;
    }
    .nav-logo svg { width: 36px; height: 36px; }
    .nav-logo-text { font-size: 1.05rem; font-weight: 700; color: var(--gold); letter-spacing: .08em; }
    .nav-logo-sub  { font-size: .6rem; color: var(--slate); letter-spacing: .25em; text-transform: uppercase; }
    nav ul { list-style: none; display: flex; gap: 2rem; }
    nav ul a { color: var(--slate); text-decoration: none; font-size: .85rem; letter-spacing: .05em;
               transition: color .2s; }
    nav ul a:hover { color: var(--gold); }
    .nav-cta {
      background: var(--gold);
      color: var(--dark0);
      border: none;
      padding: .55rem 1.4rem;
      border-radius: 6px;
      font-weight: 700;
      font-size: .85rem;
      letter-spacing: .05em;
      cursor: pointer;
      text-decoration: none;
      transition: background .2s, transform .15s;
    }
    .nav-cta:hover { background: var(--gold2); transform: translateY(-1px); }

    /* ── Hero ── */
    #hero {
      position: relative;
      z-index: 1;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 8rem 2rem 6rem;
      overflow: hidden;
    }

    /* Gorilla SVG watermark */
    .hero-bg-gorilla {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: .04;
      pointer-events: none;
    }
    .hero-bg-gorilla svg { width: min(80vw, 700px); height: auto; }

    /* Glow orbs */
    .orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(120px);
      pointer-events: none;
    }
    .orb-gold  { width: 600px; height: 600px; background: rgba(250,204,21,.08); top: -150px; left: -100px; }
    .orb-blue  { width: 500px; height: 500px; background: rgba(129,140,248,.06); bottom: -100px; right: -100px; }

    .eyebrow {
      font-size: .75rem;
      letter-spacing: .3em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: .75rem;
    }
    .eyebrow::before, .eyebrow::after {
      content: '';
      display: block;
      width: 32px;
      height: 1px;
      background: var(--gold);
      opacity: .6;
    }

    h1 {
      font-size: clamp(2.8rem, 7vw, 6rem);
      font-weight: 800;
      line-height: 1.06;
      letter-spacing: -.02em;
      max-width: 820px;
      margin-bottom: 1.5rem;
    }
    h1 em {
      font-style: normal;
      color: var(--gold);
    }

    .hero-sub {
      font-size: clamp(1rem, 2vw, 1.25rem);
      color: var(--slate);
      max-width: 560px;
      line-height: 1.7;
      margin-bottom: 3rem;
    }

    .hero-actions {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      justify-content: center;
    }
    .btn-primary {
      background: var(--gold);
      color: var(--dark0);
      border: none;
      padding: .85rem 2.2rem;
      border-radius: 8px;
      font-weight: 700;
      font-size: 1rem;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: .5rem;
      transition: background .2s, transform .15s, box-shadow .2s;
      box-shadow: 0 0 40px rgba(250,204,21,.25);
    }
    .btn-primary:hover {
      background: var(--gold2);
      transform: translateY(-2px);
      box-shadow: 0 0 60px rgba(250,204,21,.4);
    }
    .btn-outline {
      background: transparent;
      color: var(--slate);
      border: 1px solid rgba(148,163,184,.3);
      padding: .85rem 2.2rem;
      border-radius: 8px;
      font-weight: 600;
      font-size: 1rem;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: .5rem;
      transition: border-color .2s, color .2s;
    }
    .btn-outline:hover { border-color: var(--gold); color: var(--gold); }

    /* scroll indicator */
    .scroll-hint {
      position: absolute;
      bottom: 2.5rem;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: .4rem;
      color: var(--slate);
      font-size: .7rem;
      letter-spacing: .15em;
      text-transform: uppercase;
      opacity: .5;
      animation: bounce 2s ease-in-out infinite;
    }
    @keyframes bounce {
      0%, 100% { transform: translateX(-50%) translateY(0); }
      50%       { transform: translateX(-50%) translateY(6px); }
    }

    /* ── Stats bar ── */
    #stats {
      position: relative;
      z-index: 1;
      border-top: 1px solid rgba(250,204,21,.08);
      border-bottom: 1px solid rgba(250,204,21,.08);
      background: rgba(10,10,10,.6);
      backdrop-filter: blur(8px);
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0;
    }
    .stat-item {
      flex: 1 1 180px;
      text-align: center;
      padding: 2.5rem 2rem;
      border-right: 1px solid rgba(148,163,184,.1);
    }
    .stat-item:last-child { border-right: none; }
    .stat-num {
      font-size: 2.6rem;
      font-weight: 800;
      color: var(--gold);
      line-height: 1;
      letter-spacing: -.02em;
    }
    .stat-label {
      font-size: .75rem;
      color: var(--slate);
      text-transform: uppercase;
      letter-spacing: .15em;
      margin-top: .4rem;
    }

    /* ── Section shared ── */
    section { position: relative; z-index: 1; }
    .section-inner { max-width: 1100px; margin: 0 auto; padding: 6rem 2rem; }
    .section-tag {
      font-size: .7rem;
      letter-spacing: .3em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: .75rem;
    }
    .section-title {
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -.02em;
      margin-bottom: 1rem;
    }
    .section-body {
      font-size: 1.05rem;
      color: var(--slate);
      line-height: 1.8;
      max-width: 660px;
    }

    /* ── Services ── */
    .services-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
      margin-top: 4rem;
    }
    .service-card {
      background: var(--dark2);
      border: 1px solid rgba(148,163,184,.08);
      border-radius: 12px;
      padding: 2rem;
      transition: border-color .25s, transform .2s, box-shadow .25s;
    }
    .service-card:hover {
      border-color: rgba(250,204,21,.35);
      transform: translateY(-4px);
      box-shadow: 0 20px 60px rgba(0,0,0,.4);
    }
    .service-icon {
      width: 48px;
      height: 48px;
      background: rgba(250,204,21,.1);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      margin-bottom: 1.25rem;
    }
    .service-name {
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: .6rem;
    }
    .service-desc { font-size: .9rem; color: var(--slate); line-height: 1.65; }

    /* ── About / manifesto ── */
    #about { background: var(--dark2); }
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }
    @media (max-width: 720px) { .about-grid { grid-template-columns: 1fr; } }
    .about-logo-wrap {
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .about-logo-wrap svg { width: min(300px, 80vw); height: auto; }
    .manifesto-list {
      list-style: none;
      margin-top: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: .75rem;
    }
    .manifesto-list li {
      display: flex;
      gap: .75rem;
      font-size: .95rem;
      color: var(--slate);
      line-height: 1.6;
    }
    .manifesto-list li::before {
      content: '▸';
      color: var(--gold);
      flex-shrink: 0;
      margin-top: .15rem;
    }

    /* ── Nightmares / what keeps us up ── */
    #why {
      background: linear-gradient(180deg, var(--dark1) 0%, var(--dark0) 100%);
    }
    .nightmare-cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.25rem;
      margin-top: 3.5rem;
    }
    .nightmare-card {
      border: 1px solid rgba(250,204,21,.12);
      border-radius: 10px;
      padding: 1.75rem;
      background: rgba(250,204,21,.03);
    }
    .nightmare-card .nc-num {
      font-size: 3rem;
      font-weight: 900;
      color: rgba(250,204,21,.15);
      line-height: 1;
      margin-bottom: .5rem;
      font-variant-numeric: tabular-nums;
    }
    .nightmare-card .nc-title {
      font-size: 1rem;
      font-weight: 700;
      color: var(--gold);
      margin-bottom: .5rem;
    }
    .nightmare-card .nc-body { font-size: .875rem; color: var(--slate); line-height: 1.65; }

    /* ── CTA ── */
    #cta {
      background: radial-gradient(ellipse at 50% 0%, rgba(250,204,21,.07) 0%, transparent 70%),
                  var(--dark0);
      text-align: center;
    }
    #cta .section-inner { padding-top: 7rem; padding-bottom: 7rem; }
    #cta h2 { font-size: clamp(2.2rem, 5vw, 3.8rem); font-weight: 800; line-height: 1.1; letter-spacing: -.02em; }
    #cta p { margin: 1.5rem auto 2.5rem; font-size: 1.1rem; color: var(--slate); max-width: 480px; line-height: 1.7; }

    /* ── Footer ── */
    footer {
      position: relative;
      z-index: 1;
      border-top: 1px solid rgba(148,163,184,.08);
      padding: 2.5rem;
      text-align: center;
      font-size: .8rem;
      color: rgba(148,163,184,.45);
      letter-spacing: .05em;
    }
    footer a { color: rgba(148,163,184,.55); text-decoration: none; }
    footer a:hover { color: var(--gold); }

    /* ── Pulse animation on the logo ── */
    @keyframes pulse-ring {
      0%   { stroke-opacity: .6; }
      50%  { stroke-opacity: .15; }
      100% { stroke-opacity: .6; }
    }
    .pulse-ring { animation: pulse-ring 3s ease-in-out infinite; }

    /* ── Responsive nav ── */
    @media (max-width: 680px) {
      nav ul { display: none; }
      nav { padding: 1rem 1.5rem; }
    }
  </style>
</head>
